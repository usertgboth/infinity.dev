# --- Database (Postgres) ---
# On Vercel: Storage → Create Postgres → DATABASE_URL is auto-injected.
# Local dev: install Postgres OR use Neon/Supabase free tier.
DATABASE_URL="postgresql://user:password@host:5432/infinity?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# --- Google OAuth (https://console.cloud.google.com -> OAuth client) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- OpenAI ---
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Workflow engine (internal runtime) ---
N8N_BASE_URL="http://localhost:5678"
N8N_API_KEY=""

# --- Bootstrap admin (first user with this email becomes ADMIN) ---
ADMIN_EMAIL="admin@infinity.dev"
